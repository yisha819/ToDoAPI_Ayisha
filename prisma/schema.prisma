datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Todo {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("todos") 
}